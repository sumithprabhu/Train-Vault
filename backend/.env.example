# Server
PORT=3001
API_PORT=3001

# MongoDB (API keys, user wallet mapping, dataset ownership and encryption metadata only; datasets are on Filecoin via Synapse)
MONGODB_URI=mongodb://localhost:27017/corpus

# Encryption: optional. New encrypted datasets use the owner's API key. Set this only for legacy decrypt (datasets encrypted with global secret).
ENCRYPTION_SECRET=

# Filecoin network for Synapse SDK (calibration = testnet, mainnet = production)
FILECOIN_NETWORK=calibration

# Synapse SDK: operator wallet private key (hex, with or without 0x).
# Required for dataset upload and retrieval on Filecoin Calibration.
SYNAPSE_OPERATOR_PRIVATE_KEY=

# Storage treasury (contract on Filecoin Calibration)
# Deployed StorageTreasury address (Calibration)
TREASURY_CONTRACT_ADDRESS=
# RPC for Filecoin Calibration (treasury chain)
RPC_URL=https://api.calibration.node.glif.io/rpc/v1
# Backend wallet that is set as executor in the contract; use a Calibration-funded key
TREASURY_EXECUTOR_PRIVATE_KEY=
# Optional: expected executor address; if set, startup verifies it matches the private key
TREASURY_EXECUTOR_ADDRESS=
# Chain id (314159 = Filecoin Calibration)
TREASURY_CHAIN_ID=314159

# Storage cost: fixed per upload (wei, 18 decimals)
STORAGE_COST_FIXED_WEI=1000000000000000
# Storage cost per month (wei). Billed per month; access is not permanent. Defaults to STORAGE_COST_FIXED_WEI if unset.
STORAGE_COST_PER_MONTH_WEI=1000000000000000
